# ==============================================
# Environment Configuration Template
# ==============================================
# Copy this file to .env and customize values
# Docker Compose will automatically load .env file

# ==============================================
# Spring Boot Configuration
# ==============================================
SPRING_PROFILES_ACTIVE=pi

# ==============================================
# JVM Memory Settings (adjust based on your Pi's RAM)
# ==============================================
# Digital Signage Service
SIGNAGE_JAVA_OPTS=-Xmx448m -Xms128m -XX:MaxMetaspaceSize=128m -XX:+UseG1GC

# Analytics ETL Service  
ETL_JAVA_OPTS=-Xmx384m -Xms128m -XX:MaxMetaspaceSize=128m -XX:+UseG1GC

# ==============================================
# Service Ports (change if default ports conflict)
# ==============================================
DASHBOARD_PORT=80
SIGNAGE_PORT=8080
ETL_PORT=8081
TDENGINE_PORT=6030
TDENGINE_REST_PORT=6041

# ==============================================
# TDengine Configuration
# ==============================================
TDENGINE_FQDN=tdengine
TZ=Asia/Kuala_Lumpur

# ==============================================
# Database Paths (relative to docker-compose.yml)
# ==============================================
SIGNAGE_DATA_PATH=../../microservices/digital-signage-service/data
ETL_DATA_PATH=../../microservices/analytics-etl-service/data

# ==============================================
# Resource Limits (MB)
# ==============================================
# Adjust based on your Raspberry Pi model:
# Pi 4 (4GB):  Use defaults below
# Pi 4 (8GB):  Can increase by 50%
# Pi 5 (8GB+): Can double the values

TDENGINE_MEMORY_LIMIT=1024m
TDENGINE_MEMORY_RESERVATION=512m

SIGNAGE_MEMORY_LIMIT=576m
SIGNAGE_MEMORY_RESERVATION=256m

ETL_MEMORY_LIMIT=512m
ETL_MEMORY_RESERVATION=256m

DASHBOARD_MEMORY_LIMIT=128m
DASHBOARD_MEMORY_RESERVATION=64m

# ==============================================
# CPU Limits (cores)
# ==============================================
TDENGINE_CPU_LIMIT=1.5
SIGNAGE_CPU_LIMIT=1.5
ETL_CPU_LIMIT=1.0
DASHBOARD_CPU_LIMIT=0.5

# ==============================================
# Build Configuration
# ==============================================
# Set to "true" to skip Docker build and use host-built JARs
USE_PREBUILT_JARS=false

# JAR file paths (if using pre-built JARs)
SIGNAGE_JAR=target/digital-signage-service-1.0.0-SNAPSHOT.jar
ETL_JAR=target/analytics-etl-service-1.0.0-SNAPSHOT.jar

# ==============================================
# Dashboard Configuration
# ==============================================
VITE_API_BASE_URL=http://localhost:8080

# ==============================================
# Logging Configuration
# ==============================================
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_APP=INFO

# ==============================================
# Health Check Configuration
# ==============================================
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=5
HEALTHCHECK_START_PERIOD=60s
